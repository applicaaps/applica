{
  "kind": "collectionType",
  "collectionName": "documenti",
  "info": {
    "singularName": "documento",
    "pluralName": "documenti",
    "displayName": "documento"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titolo": {
      "type": "string"
    },
    "descrizione": {
      "type": "text"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "categoria": {
      "type": "enumeration",
      "enum": [
        "questionario",
        "scheda",
        "materiale_esperienziale",
        "altro"
      ]
    },
    "visibilita": {
      "type": "enumeration",
      "enum": [
        "visibilita"
      ]
    },
    "eventi": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::evento.evento",
      "inversedBy": "documenti"
    }
  }
}
